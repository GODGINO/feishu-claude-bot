{
  "name": "feishu-claude-bot",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "bot": "bash scripts/bot.sh start",
